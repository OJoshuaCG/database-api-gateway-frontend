# Base URL de la API versionada del Database API Gateway (incluye /api/v1).
# El backend debe incluir este origen del frontend en CORS_ORIGINS (no admite "*"
# junto a credenciales). Ej. dev: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# URL del health check de liveness (vive en la raíz, fuera de /api/v1, sin auth).
# Opcional: si el backend no expone CORS en /health, el badge de salud se degrada.
VITE_HEALTH_URL=http://localhost:8000/health
